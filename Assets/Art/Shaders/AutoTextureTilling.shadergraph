{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "44f93e9fd10c46e089569381f8c9f0f5",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "TriplanarFixed (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -355.99993896484377,
            "y": 199.9999542236328,
            "width": 236.0,
            "height": 198.6667022705078
        }
    },
    "m_Slots": [
        {
            "m_Id": "450aca4a8a154c488eab45ae7f18a4f8"
        },
        {
            "m_Id": "6ff6364b23a245a28254a6fe6a3b3743"
        },
        {
            "m_Id": "63170d5357d64e2097df989f666c27fe"
        },
        {
            "m_Id": "01a61e854d0e480086e4a879cc05c4df"
        },
        {
            "m_Id": "93a6ec3a830a41ed9522e4f803bf92ff"
        },
        {
            "m_Id": "4231530d323e48eea8ccb52cc5390993"
        },
        {
            "m_Id": "54c69bf03e7d44098d75761a0b151b8b"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "TriplanarFixed",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 n = pow(abs(WorldNormal), Blend);\r\nn /= (n.x + n.y + n.z);\r\n\nfloat2 uvX = WorldPos.zy * Tile;\r\nfloat2 uvY = WorldPos.xz * Tile;\r\nfloat2 uvZ = WorldPos.xy * Tile;\r\n\r\nuvX.x *= sign(WorldNormal.x);\r\nuvY.x *= sign(WorldNormal.y);\r\nuvZ.x *= -sign(WorldNormal.z);\r\n\r\nfloat4 cx = SAMPLE_TEXTURE2D(Tex.tex, SS.samplerstate, uvX);\r\nfloat4 cy = SAMPLE_TEXTURE2D(Tex.tex, SS.samplerstate, uvY);\r\nfloat4 cz = SAMPLE_TEXTURE2D(Tex.tex, SS.samplerstate, uvZ);\r\n\r\nOut = cx * n.x + cy * n.y + cz * n.z;"
}

